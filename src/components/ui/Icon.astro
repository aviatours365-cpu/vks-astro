---
import { ICONS } from "@/lib/icons";

interface Props {
  name: keyof typeof ICONS;
  class?: string;
  size?: number;
}

const { name, class: className = "", size = 24 } = Astro.props;

const filledIcons = ["viber", "whatsapp"];
const fillType = filledIcons.includes(name) ? "currentColor" : "none";
const viewbox = "0 0 24 24";
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox={viewbox}
  fill={fillType}
  xmlns="http://www.w3.org/2000/svg"
  set:html={ICONS[name]}
/>
