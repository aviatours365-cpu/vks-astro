---
import { cn } from "@/utils/cn";
import Icon from "@/components/ui/Icon.astro";

interface Props {
  icon: string;
  title: string;
  description: string;
  full: string;
  className?: string;
}

const { icon, title, description, full, className } = Astro.props;

// Format text seamlessly to avoid line breaks (continuous paragraph)
const textSuffix = full.startsWith(",") ? full : " " + full;
---

{
  /* Mobile: relative flow, click to expand. Desktop: absolute overlay, hover to expand */
}
<div
  class={cn(
    "service-card group relative w-full z-10 hover:z-50",
    "h-auto md:h-[340px]",
    className,
  )}
>
  <div
    class={cn(
      "service-card-inner",
      "md:absolute md:top-0 md:left-0 w-full bg-white rounded-xl p-8 lg:p-10 border border-[#e1e1e1] overflow-hidden",
      "transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] origin-top",
      "md:group-hover:shadow-[0_16px_40px_rgba(0,123,255,0.12)] md:group-hover:border-transparent md:group-hover:scale-[1.03] md:group-hover:-translate-y-2",
      "md:min-h-full md:max-h-[340px] md:group-hover:max-h-[800px]",
    )}
  >
    {/* Hexagon Icon */}
    <div
      class="relative w-max overflow-hidden rounded-md mb-6 transition-transform duration-500 ease-out after:content-[''] after:absolute after:top-0 after:-left-[150%] after:w-[150%] after:h-[150%] after:bg-gradient-to-r after:from-transparent after:via-white/70 after:to-transparent after:-skew-x-[20deg] group-hover:after:animate-[shine_1s_ease-out_forwards]"
    >
      <Icon
        name={icon as any}
        size={64}
        class="text-blue transition-colors duration-500"
      />
    </div>

    {/* Title + Toggle arrow on mobile */}
    <div class="flex items-start justify-between gap-4 mb-4">
      <h3
        class="font-display font-bold text-xl uppercase tracking-wider text-navy transition-colors duration-500 group-hover:text-blue"
      >
        {title}
      </h3>
      <svg
        class="service-card-arrow w-5 h-5 text-navy/30 shrink-0 mt-1 transition-transform duration-300 md:hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
        ></path>
      </svg>
    </div>

    {/* Text Block */}
    <p
      class="font-sans text-[15px] text-navy/60 leading-relaxed font-light mb-0"
    >
      {description}
      <span
        class="service-card-full hidden md:inline md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300"
      >
        {textSuffix}
      </span>
    </p>
  </div>
</div>

<script>
  document.querySelectorAll(".service-card").forEach((card) => {
    if (window.innerWidth >= 768) return; // Desktop uses CSS hover

    const inner = card.querySelector(".service-card-inner") as HTMLElement;
    const fullText = card.querySelector(".service-card-full") as HTMLElement;
    const arrow = card.querySelector(".service-card-arrow") as HTMLElement;
    let isOpen = false;

    card.addEventListener("click", () => {
      isOpen = !isOpen;

      if (isOpen) {
        fullText?.classList.remove("hidden");
        fullText?.classList.add("inline");
        arrow?.classList.add("rotate-180");
        inner?.classList.add(
          "shadow-[0_8px_24px_rgba(0,123,255,0.1)]",
          "border-transparent",
        );
      } else {
        fullText?.classList.add("hidden");
        fullText?.classList.remove("inline");
        arrow?.classList.remove("rotate-180");
        inner?.classList.remove(
          "shadow-[0_8px_24px_rgba(0,123,255,0.1)]",
          "border-transparent",
        );
      }
    });
  });
</script>
