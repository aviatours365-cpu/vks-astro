---
import { cn } from "@/utils/cn";
import Icon from "@/components/ui/Icon.astro";

interface Props {
  icon: string;
  title: string;
  description: string;
  full: string;
  className?: string;
}

const { icon, title, description, full, className } = Astro.props;

const textSuffix = full.startsWith(",") ? full : " " + full;
---

{
  /* Mobile: relative flow, click to expand with smooth animation. Desktop: absolute overlay, hover */
}
<div
  class={cn(
    "service-card group relative w-full z-10 hover:z-50",
    "h-auto md:h-[340px]",
    className,
  )}
>
  <div
    class={cn(
      "service-card-inner",
      "md:absolute md:top-0 md:left-0 w-full bg-white rounded-xl p-8 lg:p-10 border border-[#e1e1e1] overflow-hidden",
      "transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] origin-top",
      "md:group-hover:shadow-[0_16px_40px_rgba(0,123,255,0.12)] md:group-hover:border-transparent md:group-hover:scale-[1.03] md:group-hover:-translate-y-2",
      "md:min-h-full md:max-h-[340px] md:group-hover:max-h-[800px]",
    )}
  >
    {/* Icon */}
    <div
      class="relative w-max overflow-hidden rounded-md mb-6 transition-transform duration-500 ease-out after:content-[''] after:absolute after:top-0 after:-left-[150%] after:w-[150%] after:h-[150%] after:bg-gradient-to-r after:from-transparent after:via-white/70 after:to-transparent after:-skew-x-[20deg] group-hover:after:animate-[shine_1s_ease-out_forwards]"
    >
      <Icon
        name={icon as any}
        size={64}
        class="text-blue transition-colors duration-500"
      />
    </div>

    {/* Title */}
    <h3
      class="font-display font-bold text-xl uppercase tracking-wider text-navy mb-4 transition-colors duration-500 group-hover:text-blue pr-8"
    >
      {title}
    </h3>

    {/* Text Block */}
    <p
      class="font-sans text-[15px] text-navy/60 leading-relaxed font-light mb-0"
    >
      {description}
      <span
        class="service-card-full transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] inline-block max-h-0 md:max-h-none overflow-hidden opacity-0 md:group-hover:opacity-100 md:group-hover:max-h-[400px]"
      >
        {textSuffix}
      </span>
    </p>
  </div>
</div>

<script>
  document.querySelectorAll(".service-card").forEach((card) => {
    if (window.innerWidth >= 768) return;

    const inner = card.querySelector(".service-card-inner") as HTMLElement;
    const fullText = card.querySelector(".service-card-full") as HTMLElement;
    let isOpen = false;

    card.addEventListener("click", () => {
      isOpen = !isOpen;

      if (isOpen) {
        fullText.style.maxHeight = fullText.scrollHeight + "px";
        fullText.style.opacity = "1";
        inner?.classList.add(
          "shadow-[0_8px_24px_rgba(0,123,255,0.1)]",
          "border-transparent",
        );
      } else {
        fullText.style.maxHeight = "0px";
        fullText.style.opacity = "0";
        inner?.classList.remove(
          "shadow-[0_8px_24px_rgba(0,123,255,0.1)]",
          "border-transparent",
        );
      }
    });
  });
</script>
