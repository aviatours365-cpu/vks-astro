---
import { cn } from "@/utils/cn";
import Icon from "@/components/ui/Icon.astro";
import { url } from "@/utils/url";

interface Props {
  slug: string;
  icon: string;
  title: string;
  description: string;
  full: string;
  className?: string;
}

const { slug, icon, title, description, full, className } = Astro.props;

const textSuffix = full.startsWith(",") ? full : " " + full;
---

<a
  href={url(`/uslugi/${slug}`)}
  class={cn(
    "service-card group relative w-full z-10 hover:z-50 block text-left",
    "h-auto md:h-[340px]",
    className,
  )}
>
  <div
    class={cn(
      "service-card-inner",
      "md:absolute md:top-0 md:left-0 w-full bg-white rounded-xl p-8 lg:p-10 border border-[#e1e1e1] overflow-hidden",
      "transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] origin-top",
      "md:group-hover:shadow-[0_20px_50px_rgba(0,123,255,0.15)] md:group-hover:border-transparent md:group-hover:-translate-y-3",
      "md:min-h-full md:max-h-[340px] md:group-hover:max-h-[800px]",
    )}
  >
    {/* Icon */}
    <div
      class="relative mb-6 w-max overflow-hidden rounded-md transition-transform duration-500 ease-out after:absolute after:-left-[150%] after:top-0 after:h-[150%] after:w-[150%] after:-skew-x-[20deg] after:bg-gradient-to-r after:from-transparent after:via-white/70 after:to-transparent after:content-[''] group-hover:after:animate-[shine_1s_ease-out_forwards]"
    >
      <Icon
        name={icon as any}
        size={64}
        class="text-blue transition-colors duration-500"
      />
    </div>

    {/* Title */}
    <h3
      class="mb-4 pr-8 font-display text-xl font-bold uppercase tracking-wider text-navy transition-colors duration-500 group-hover:text-blue"
    >
      {title}
    </h3>

    {/* Single continuous paragraph — no text breaks */}
    <p
      class="service-card-text text-navy/60 mb-0 font-sans text-[15px] font-light leading-relaxed"
    >
      {description}<span
        class="service-card-full md:opacity-0 md:transition-opacity md:duration-300 md:group-hover:opacity-100"
        >{textSuffix}</span
      >
    </p>
  </div>
</a>
