---
import HexBadge from "./HexBadge.astro";

export interface Props {
  city: string;
  projects?: number;
}

const { city, projects } = Astro.props;
---

<div
  class="pointer-events-none absolute bottom-5 left-1/2 z-50 flex -translate-x-1/2 flex-col items-center opacity-0 transition-all duration-300 group-hover:opacity-100"
>
  <div
    class="relative z-20 flex min-w-[124px] flex-col items-center justify-center rounded-2xl border border-white bg-white/95 px-5 py-4 text-center shadow-[0_10px_40px_rgba(0,0,0,0.08)] backdrop-blur-sm"
  >
    <span class="mb-2 font-display text-[15px] font-bold text-navy">{city}</span
    >

    {projects && <HexBadge count={projects} label="ПРОЕКТОВ" />}
  </div>

  <div
    class="z-10 -mt-2.5 h-6 w-6 rotate-45 border-b border-r border-[#E5E7EB]/50 bg-white/95 shadow-[4px_4px_10px_rgba(0,0,0,0.03)]"
  >
  </div>
</div>
