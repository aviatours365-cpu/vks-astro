---
interface Props {
  product: any;
  index: number;
}

const { product, index } = Astro.props;
---

<div
  class={`editorial-accordion mb-3 overflow-hidden rounded-xl border bg-white transition-all duration-300 scroll-mt-[100px] ${index === 0 ? "border-transparent shadow-[0_8px_30px_rgba(0,123,255,0.12)]" : "border-[#e1e1e1] hover:border-transparent hover:shadow-[0_8px_30px_rgba(0,123,255,0.12)]"}`}
>
  <button
    class="editorial-trigger group flex w-full items-center gap-4 px-5 py-5 text-left transition-all duration-300"
    aria-expanded={index === 0 ? "true" : "false"}
    aria-controls={`panel-${product.id}`}
  >
    <div
      class="bg-navy/[0.06] flex h-9 w-9 shrink-0 items-center justify-center rounded-lg"
    >
      <span
        class="text-navy/40 font-display text-[13px] font-bold transition-colors duration-300 group-aria-expanded:text-blue"
      >
        {String(index + 1).padStart(2, "0")}
      </span>
    </div>
    <h4
      class="flex-1 font-display text-sm font-bold uppercase tracking-[0.03em] text-navy transition-colors duration-300 group-aria-expanded:text-blue"
    >
      {product.title}
    </h4>
    <svg
      class={`editorial-chevron text-navy/25 shrink-0 transition-all duration-500 group-aria-expanded:text-blue ${index === 0 ? "rotate-180" : ""}`}
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M6 9l6 6 6-6"></path>
    </svg>
  </button>

  <div
    id={`panel-${product.id}`}
    class="editorial-panel grid transition-all duration-300 ease-in-out"
    style={index === 0
      ? "grid-template-rows: 1fr; opacity: 1;"
      : "grid-template-rows: 0fr; opacity: 0;"}
  >
    <div class="overflow-hidden">
      <div class="px-5 pb-6 pt-4">
        <p
          class="text-navy/60 mb-6 font-sans text-[14px] font-normal leading-relaxed"
        >
          {product.description}
        </p>

        <div class="border-t border-[#e1e1e1]/60 pt-4">
          <ul class="flex flex-col gap-3">
            {
              product.features.map((feature: string) => (
                <li class="flex items-start gap-2.5">
                  <div class="mt-[6px] h-[6px] w-[6px] shrink-0 rounded-full bg-blue" />
                  <span class="text-navy/55 text-[13px] font-normal leading-snug">
                    {feature}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
