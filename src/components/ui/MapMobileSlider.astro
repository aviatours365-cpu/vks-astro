---
import HexBadge from "./HexBadge.astro";

export interface Props {
  stats: {
    city: string;
    projects?: number;
    [key: string]: any;
  }[];
}

const { stats } = Astro.props;
---

<div class="flex w-full flex-col overflow-hidden lg:hidden">
  <div
    class="-mx-4 flex w-full snap-x snap-mandatory gap-4 overflow-x-auto px-4 pb-8 md:-mx-6 md:px-6 [&::-webkit-scrollbar]:hidden"
  >
    {
      stats.map((stat) => (
        <div class="flex w-[260px] shrink-0 snap-center flex-col rounded-2xl border border-[#E5E7EB] bg-white p-6 shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
          <span class="mb-5 block font-display text-base font-bold text-navy">
            {stat.city}
          </span>

          <div class="mt-auto flex w-max flex-col items-start">
            {stat.projects !== undefined && (
              <HexBadge count={stat.projects} label="ПРОЕКТОВ" />
            )}
          </div>
        </div>
      ))
    }
  </div>
</div>
