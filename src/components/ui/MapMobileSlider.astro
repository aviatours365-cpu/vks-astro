---
import HexBadge from "./HexBadge.astro";

export interface Props {
  stats: {
    city: string;
    projects?: number;
    [key: string]: any;
  }[];
}

const { stats } = Astro.props;
---

<div class="mt-8 flex w-full flex-col overflow-hidden lg:hidden">
  <div
    id="map-mobile-slider"
    class="-mx-4 flex w-full snap-x snap-mandatory items-stretch gap-6 overflow-x-auto px-4 pb-8 pt-10 md:mx-0 md:overflow-visible md:px-0 md:pb-0 md:pt-0 [&::-webkit-scrollbar]:hidden"
  >
    {
      stats.map((stat, i) => (
        <div 
          class="map-stat-card group relative flex w-[280px] shrink-0 snap-center snap-always flex-col rounded-xl border border-[#e1e1e1] bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.03)] transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] transform-gpu will-change-transform [&.is-active]:shadow-[0_20px_50px_rgba(0,123,255,0.15)] [&.is-active]:border-transparent [&.is-active]:-translate-y-3"
          data-index={i}
        >
          <span class="mb-5 block font-display text-lg font-bold text-navy transition-colors duration-500 group-hover:text-blue [&.is-active]:text-blue">
            {stat.city}
          </span>

          <div class="mt-auto flex w-max flex-col items-start">
            {stat.projects !== undefined && (
              <HexBadge count={stat.projects} label="ПРОЕКТОВ" />
            )}
          </div>
        </div>
      ))
    }
  </div>

  {/* Pagination Dots for Mobile */}
  <div
    class="mt-4 flex justify-center gap-3 md:hidden"
    role="tablist"
    aria-label="Навигация по карте"
  >
    {
      stats.map((_, i) => (
        <button
          class="map-dot h-2 w-2 rounded-full bg-navy opacity-20 transition-all duration-300 aria-selected:w-6 aria-selected:bg-blue aria-selected:opacity-100"
          data-index={i}
          role="tab"
          aria-label={`Слайд ${i + 1}`}
          aria-selected={i === 0 ? "true" : "false"}
        />
      ))
    }
  </div>
</div>

<script>
  function updateMapDots(
    index: number,
    dots: NodeListOf<Element>,
    cards: NodeListOf<Element>,
  ) {
    dots.forEach((dot, i) => {
      dot.setAttribute("aria-selected", i === index ? "true" : "false");
    });
    cards.forEach((card, i) => {
      card.classList.toggle("is-active", i === index);
    });
  }

  function initMapSlider() {
    const slider = document.getElementById("map-mobile-slider");
    const dots = document.querySelectorAll(".map-dot");
    const cards = document.querySelectorAll(".map-stat-card");

    if (!slider || dots.length === 0 || cards.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        const mostVisible = entries.reduce((prev, curr) =>
          curr.intersectionRatio > prev.intersectionRatio ? curr : prev,
        );
        if (mostVisible && mostVisible.intersectionRatio > 0.5) {
          const index = Array.from(cards).indexOf(mostVisible.target);
          updateMapDots(index, dots, cards);
        }
      },
      { root: slider, threshold: 0.6 },
    );

    cards.forEach((card) => observer.observe(card));

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        const targetCard = cards[i] as HTMLElement;
        if (targetCard) {
          slider.scrollTo({
            left: targetCard.offsetLeft - slider.offsetLeft,
            behavior: "smooth",
          });
          updateMapDots(i, dots, cards);
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initMapSlider);
  initMapSlider();
</script>
