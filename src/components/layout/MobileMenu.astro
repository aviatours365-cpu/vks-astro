---
import { NAV_LINKS, CONTACTS, UI } from "@/lib/constants";
import { url } from "@/utils/url";
import Icon from "@/components/ui/Icon.astro";

interface Props {
  class?: string;
}
---

{/* Mobile Menu Trigger */}
<button
  id="menu-toggle"
  class="group relative z-50 flex items-center gap-3 text-navy transition-colors hover:text-blue md:hidden"
  aria-label={UI.openMenu}
  aria-controls="mobile-menu"
  aria-expanded="false"
>
  <div class="relative flex h-7 w-7 items-center justify-center">
    <Icon
      name="burger"
      class="absolute inset-0 h-7 w-7 transition-opacity duration-300 ease-in-out"
    />
    <Icon
      name="close"
      class="absolute inset-0 h-7 w-7 text-white opacity-0 transition-opacity duration-300 ease-in-out"
    />
  </div>
  <span
    class="hidden font-display text-sm uppercase tracking-widest transition-colors group-hover:text-blue sm:block"
  >
    {UI.menu}
  </span>
</button>

{/* Mobile Menu Overlay */}
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 translate-x-full transform overflow-y-auto bg-[#0a1128] text-white transition-transform duration-500 ease-in-out md:hidden"
>
  <div class="mx-auto flex h-full w-full max-w-sm flex-col px-6 pb-12 pt-24">
    {/* Navigation */}
    <div
      class="mobile-link mb-auto flex translate-y-8 flex-col gap-6 opacity-0"
      style="transition-delay: 100ms"
    >
      <h4
        class="font-display text-[10px] font-bold uppercase tracking-[0.2em] text-white/30"
      >
        {UI.navigation}
      </h4>
      <nav class="flex flex-col gap-4">
        {
          NAV_LINKS.map((link) => (
            <a
              href={url(link.href)}
              class="mobile-nav-link text-[18px] font-light text-white/90 transition-colors duration-300 hover:text-white"
              onclick="document.getElementById('menu-toggle')?.click()"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    {/* Phones & Contacts */}
    <div
      class="mobile-link mb-12 mt-12 flex translate-y-8 flex-col gap-10 opacity-0"
      style="transition-delay: 200ms"
    >
      {/* Phones */}
      <div class="flex flex-col gap-6">
        <h4
          class="font-display text-[10px] font-bold uppercase tracking-[0.2em] text-white/30"
        >
          {UI.phones}
        </h4>
        <ul class="flex flex-col gap-4">
          {
            CONTACTS.phones.map((phone) => (
              <li class="flex items-center gap-4">
                <Icon
                  name="phone"
                  size={16}
                  class="shrink-0 text-white/40"
                />
                <a
                  href={`tel:${phone.value.replace(/[^+\d]/g, "")}`}
                  class="whitespace-nowrap text-[16px] font-light tracking-wide text-white/90 transition-colors hover:text-white"
                >
                  {phone.value}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Contacts */}
      <div class="flex flex-col gap-6 border-t border-white/10 pt-8">
        <h4
          class="font-display text-[10px] font-bold uppercase tracking-[0.2em] text-white/30"
        >
          {UI.contacts}
        </h4>
        <div class="flex flex-col gap-6">
          <div>
            <p
              class="mb-2 text-[10px] font-semibold uppercase tracking-widest text-white/40"
            >
              {UI.office}
            </p>
            <address
              class="text-[15px] font-light not-italic leading-[1.6] text-white/90"
            >
              {CONTACTS.address.full.join(", ")}
            </address>
          </div>
          <div>
            <p
              class="mb-2 text-[10px] font-semibold uppercase tracking-widest text-white/40"
            >
              {UI.email}
            </p>
            <a
              href={`mailto:${CONTACTS.email}`}
              class="text-[15px] font-light text-white/90 transition-colors hover:text-white"
            >
              {CONTACTS.email}
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* Social Icons */}
    <div
      class="mobile-link flex translate-y-8 items-center gap-4 border-t border-white/10 pt-8 opacity-0"
      style="transition-delay: 300ms"
    >
      {
        CONTACTS.socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-white/50 transition-all duration-300 hover:bg-white/10 hover:text-white"
            aria-label={social.label}
          >
            <Icon name={social.name} size={18} class="fill-current" />
          </a>
        ))
      }
    </div>
  </div>
</div>
