---
import { SITE, UI } from "@/lib/constants";
import { url } from "@/utils/url";

const currentYear = new Date().getFullYear();
---

<footer
  transition:name="main-footer"
  transition:persist="main-footer"
  class="relative mt-auto border-t border-white/5 bg-[#0a1128] py-8 text-white"
>
  <div class="container relative z-10 mx-auto max-w-7xl px-4 md:px-6">
    <div
      class="flex flex-col items-start justify-between gap-8 lg:flex-row lg:items-center"
    >
      <div class="flex flex-col gap-2">
        <p class="text-[11px] tracking-wide text-white/30 lg:text-xs">
          &copy; {currentYear}
          {SITE.name}. {UI.allRightsReserved}
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-x-8 gap-y-4">
        <a
          href={url(SITE.privacyPolicyUrl)}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[11px] tracking-wide text-white/40 transition-all duration-300 hover:text-white lg:text-xs"
        >
          {UI.privacyPolicy}
        </a>
        <a
          href={url("/cookie")}
          class="text-[11px] tracking-wide text-white/40 transition-all duration-300 hover:text-white lg:text-xs"
        >
          {UI.cookiePolicy}
        </a>
      </div>
    </div>
  </div>
</footer>
