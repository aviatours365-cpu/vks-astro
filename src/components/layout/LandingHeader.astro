---
import { cn } from "@/utils/cn";
import { UI, NAV_ANCHORS } from "@/lib/constants";
import logo from "@/assets/logo.webp";
import { Image } from "astro:assets";
import Button from "@/components/ui/Button.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";

interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<header
  id="main-header"
  class={cn(
    "fixed top-0 left-0 right-0 z-[100] transition-all duration-300 py-2",
    className,
  )}
>
  {/* Blur background — separate element so it doesn't trap fixed children */}
  <div
    id="header-bg"
    class="absolute inset-0 -z-10 bg-white/70 backdrop-blur-md transition-all duration-300"
  >
  </div>

  <div class="container relative mx-auto max-w-7xl px-4 md:px-6">
    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between">
      {/* Logo — scroll to top */}
      <a
        href="#"
        id="landing-logo"
        class="group flex items-center gap-2"
        aria-label="На главную"
      >
        <Image
          src={logo}
          alt="VKS Logo"
          class="h-10 w-auto object-contain"
          loading="eager"
        />
      </a>

      {/* Desktop anchor nav */}
      <nav class="hidden items-center gap-10 md:flex" aria-label="Навигация">
        {
          NAV_ANCHORS.map((link) => (
            <a
              href={link.href}
              class="landing-nav-link text-navy/70 relative font-display text-xs font-bold uppercase tracking-[0.1em] transition-colors duration-300 after:absolute after:-bottom-1 after:left-0 after:h-[2px] after:w-0 after:bg-blue after:transition-all after:duration-300 after:content-[''] hover:text-blue hover:after:w-full aria-[current=true]:text-blue aria-[current=true]:after:w-full"
              data-section={link.href.slice(1)}
            >
              {link.label}
            </a>
          ))
        }
        <Button
          href="#contact"
          variant="outline"
          size="md"
          className="landing-cta-btn h-10 rounded-full px-8 text-xs font-bold uppercase tracking-[0.1em]"
        >
          {UI.discussProject}
        </Button>
      </nav>

      {/* Mobile Menu (Island) */}
      <MobileMenu />
    </div>
  </div>
</header>

<script>
  let isScrollAttached = false;

  const handleScroll = () => {
    const header = document.getElementById("main-header");
    const headerBg = document.getElementById("header-bg");
    if (!header || !headerBg) return;
    if (window.scrollY > 10) {
      header.classList.add("py-1");
      header.classList.remove("py-2");
      headerBg.classList.add("bg-white/95", "shadow-sm");
      headerBg.classList.remove("bg-white/70");
    } else {
      header.classList.remove("py-1");
      header.classList.add("py-2");
      headerBg.classList.remove("bg-white/95", "shadow-sm");
      headerBg.classList.add("bg-white/70");
    }
  };

  // Smooth scroll for all anchor links
  const initSmoothScroll = () => {
    const headerEl = document.getElementById("main-header");
    const headerHeight = headerEl?.offsetHeight ?? 72;

    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        const href = anchor.getAttribute("href");
        if (!href || href === "#") {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: "smooth" });
          return;
        }
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          const top =
            target.getBoundingClientRect().top +
            window.scrollY -
            headerHeight -
            8;
          window.scrollTo({ top, behavior: "smooth" });
        }
      });
    });
  };

  // Active section highlight via IntersectionObserver
  const initActiveSection = () => {
    const navLinks =
      document.querySelectorAll<HTMLElement>(".landing-nav-link");
    if (!navLinks.length) return;

    const sections = Array.from(navLinks)
      .map((link) => {
        const id = link.dataset.section;
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean) as HTMLElement[];

    const setActive = (id: string | null) => {
      navLinks.forEach((link) => {
        const matches = id ? link.dataset.section === id : false;
        link.setAttribute("aria-current", matches ? "true" : "false");
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      {
        rootMargin: "-50% 0px -45% 0px",
        threshold: 0,
      },
    );

    sections.forEach((s) => observer.observe(s));
  };

  const initHeader = () => {
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const burgerIcon = menuToggle?.querySelector("svg:first-of-type");
    const closeIcon = menuToggle?.querySelector("svg:last-of-type");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    let isMenuOpen = false;

    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;
      if (isMenuOpen) {
        mobileMenu?.classList.remove("translate-x-full");
        document.body.style.overflow = "hidden";
        burgerIcon?.classList.add("opacity-0");
        closeIcon?.classList.remove("opacity-0");
        setTimeout(() => {
          mobileLinks.forEach((link) => {
            link.classList.remove("translate-y-8", "opacity-0");
          });
        }, 100);
      } else {
        mobileMenu?.classList.add("translate-x-full");
        document.body.style.overflow = "";
        burgerIcon?.classList.remove("opacity-0");
        closeIcon?.classList.add("opacity-0");
        mobileLinks.forEach((link) => {
          link.classList.add("translate-y-8", "opacity-0");
        });
      }
    };

    menuToggle?.addEventListener("click", toggleMenu);

    if (!isScrollAttached) {
      window.addEventListener("scroll", handleScroll, { passive: true });
      isScrollAttached = true;
    }

    handleScroll();
    initSmoothScroll();
    initActiveSection();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeader);
  } else {
    initHeader();
  }

  document.addEventListener("astro:page-load", initHeader);
</script>
