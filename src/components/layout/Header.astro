---
import { cn } from "@/utils/cn";
import { url } from "@/utils/url";
import { NAV_LINKS, UI } from "@/lib/constants";
import Button from "@/components/ui/Button.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";
import logo from "@/assets/logo.webp";
import { Image } from "astro:assets";

interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<header
  id="main-header"
  class={cn(
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-2",
    className,
  )}
>
  {
    /* The blur background is separated to prevent creating a containing block that traps the fixed MobileMenu overlay */
  }
  <div
    id="header-bg"
    class="absolute inset-0 -z-10 bg-white/70 backdrop-blur-md transition-all duration-300"
  >
  </div>

  <div class="container relative mx-auto max-w-7xl px-4 md:px-6">
    <div class="flex h-16 items-center justify-between">
      {/* Logo */}
      <a href={url("/")} class="group flex items-center gap-2">
        <Image
          src={logo}
          alt="VKS Logo"
          class="h-10 w-auto object-contain"
          loading="eager"
        />
      </a>

      {/* Desktop Menu */}
      <nav class="hidden items-center gap-12 md:flex">
        {
          NAV_LINKS.map((link) => (
            <a
              href={url(link.href)}
              class="text-navy/80 relative font-display text-xs font-bold uppercase tracking-[0.1em] transition-colors after:absolute after:-bottom-1 after:left-0 after:h-[2px] after:w-0 after:bg-blue after:transition-all after:content-[''] hover:text-blue hover:after:w-full"
            >
              {link.label}
            </a>
          ))
        }
        <Button
          href="#contact"
          variant="outline"
          size="md"
          className="h-10 rounded-full px-8 text-xs font-bold uppercase tracking-[0.1em]"
        >
          {UI.discussProject}
        </Button>
      </nav>

      {/* Mobile Menu (Island) */}
      <MobileMenu />
    </div>
  </div>
</header>

<script>
  let isScrollAttached = false;

  const handleScroll = () => {
    const header = document.getElementById("main-header");
    const headerBg = document.getElementById("header-bg");
    if (!header || !headerBg) return;
    if (window.scrollY > 10) {
      header.classList.add("py-1");
      header.classList.remove("py-2");
      headerBg.classList.add("bg-white/95", "shadow-sm");
      headerBg.classList.remove("bg-white/70");
    } else {
      header.classList.remove("py-1");
      header.classList.add("py-2");
      headerBg.classList.remove("bg-white/95", "shadow-sm");
      headerBg.classList.add("bg-white/70");
    }
  };

  const initHeader = () => {
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const burgerIcon = menuToggle?.querySelector("svg:first-of-type");
    const closeIcon = menuToggle?.querySelector("svg:last-of-type");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    let isMenuOpen = false;

    const openMenu = () => {
      isMenuOpen = true;
      mobileMenu?.classList.remove("translate-x-full");
      menuToggle?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
      burgerIcon?.classList.add("opacity-0");
      closeIcon?.classList.remove("opacity-0");
      setTimeout(() => {
        mobileLinks.forEach((link) => {
          link.classList.remove("translate-y-8", "opacity-0");
        });
      }, 100);
    };

    const closeMenu = () => {
      isMenuOpen = false;
      mobileMenu?.classList.add("translate-x-full");
      menuToggle?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      burgerIcon?.classList.remove("opacity-0");
      closeIcon?.classList.add("opacity-0");
      mobileLinks.forEach((link) => {
        link.classList.add("translate-y-8", "opacity-0");
      });
    };

    const toggleMenu = () => {
      if (isMenuOpen) closeMenu();
      else openMenu();
    };

    menuToggle?.addEventListener("click", toggleMenu);

    // Auto-close menu when any navigation link is clicked
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest(".mobile-nav-link")) {
        closeMenu();
      }
    });

    if (!isScrollAttached) {
      window.addEventListener("scroll", handleScroll);
      isScrollAttached = true;
    }
    handleScroll();
  };

  // Run on first load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeader);
  } else {
    initHeader();
  }

  // Support for Astro View Transitions (if re-enabled in the future)
  document.addEventListener("astro:page-load", initHeader);
</script>
