---
interface Props {
  number: string;
  title: string;
}

const { number, title } = Astro.props;
---

<div
  class="not-prose group mb-3 flex items-start gap-4 overflow-hidden rounded-xl border border-[#e1e1e1] bg-white px-5 py-5 transition-all duration-300 hover:border-transparent hover:shadow-[0_8px_30px_rgba(0,123,255,0.12)]"
>
  <div
    class="bg-navy/[0.06] flex h-9 w-9 shrink-0 items-center justify-center rounded-lg"
  >
    <span
      class="text-navy/40 font-display text-[13px] font-bold transition-colors duration-300 group-hover:text-blue"
    >
      {number}
    </span>
  </div>
  <div class="flex-1 pt-1">
    <h4
      class="mb-3 font-display text-sm font-bold uppercase tracking-[0.03em] text-navy transition-colors duration-300 group-hover:text-blue"
    >
      {title}
    </h4>
    <p class="text-navy/60 font-sans text-[14px] font-normal leading-relaxed">
      <slot />
    </p>
  </div>
</div>
