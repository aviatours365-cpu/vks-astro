---
import Icon from "@/components/ui/Icon.astro";

interface Props {
  title: string;
  icon?: string;
}

const { title, icon = "check" } = Astro.props;
---

<div
  class="group relative overflow-hidden rounded-xl border border-[#e1e1e1] bg-white p-5 shadow-[0_4px_20px_rgba(0,0,0,0.03)] transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] hover:-translate-y-3 hover:border-transparent hover:shadow-[0_20px_50px_rgba(0,123,255,0.15)] lg:p-6"
>
  <div class="mb-3 transition-transform duration-500 ease-out">
    <Icon
      name={icon as any}
      size={40}
      class="h-10 w-10 text-blue transition-colors duration-500 md:h-12 md:w-12"
    />
  </div>
  <h3
    class="mb-2 font-display text-xl font-bold uppercase tracking-wider text-navy transition-colors duration-500 group-hover:text-blue"
  >
    {title}
  </h3>
  <p class="text-navy/60 font-sans text-[15px] font-normal leading-relaxed">
    <slot />
  </p>
</div>
