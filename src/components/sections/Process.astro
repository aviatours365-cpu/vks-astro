---
import { SECTIONS } from "@/lib/constants";

interface Props {
  title?: string;
  description?: string;
  steps?: readonly {
    readonly id: string;
    readonly title: string;
    readonly description: string;
    readonly coordinates: string;
  }[];
}

const {
  title = SECTIONS.process.title,
  description = SECTIONS.process.description,
  steps = SECTIONS.process.steps,
} = Astro.props;

const hexPath =
  "M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z";
---

<section id="process" class="relative bg-surface py-12 md:py-16 lg:py-20">
  <div class="container mx-auto max-w-7xl px-4 md:px-6">
    <div class="flex flex-col items-start gap-12 lg:flex-row lg:gap-24">
      {/* ── Left Column: Sticky Header ── */}
      <div class="lg:sticky lg:top-28 lg:h-fit lg:w-2/5">
        <h2
          class="font-display text-3xl font-bold uppercase leading-[1.1] tracking-tight text-navy md:text-4xl lg:text-[2.75rem]"
        >
          {title}
        </h2>

        <p
          class="text-navy/70 mt-6 font-sans text-base leading-relaxed md:text-lg lg:text-xl"
        >
          {description}
        </p>
      </div>

      {/* ── Right Column: Immersive Stepper ── */}
      <div class="relative lg:w-3/5">
        {/* Central Vertical Line (Progress Track) */}
        <div class="absolute left-6 top-0 h-full w-px bg-line md:left-8">
          <div
            id="process-progress-bar"
            class="absolute top-0 w-full origin-top bg-blue transition-transform duration-300 ease-out"
            style="height: 100%; transform: scaleY(0);"
          >
          </div>
        </div>

        <div class="flex flex-col gap-16 md:gap-24">
          {
            steps.map((step, index) => (
              <div
                class="process-step group relative pl-16 opacity-0 transition-all duration-1000 md:pl-24"
                data-index={index}
              >
                {/* Step Hexagon Container */}
                <div class="absolute left-0 top-0 flex h-12 w-12 items-center justify-center transition-all duration-500 md:h-16 md:w-16">
                  <svg
                    viewBox="0 0 24 24"
                    class="absolute inset-0 h-full w-full transition-all duration-500"
                  >
                    {/* Shadow/Glow effect on active */}
                    <path
                      d={hexPath}
                      stroke="none"
                      class="fill-blue/10 opacity-0 transition-opacity duration-500 group-[.active]:opacity-100"
                      transform="scale(1.15) translate(-1.5, -1.5)"
                    />
                    {/* Background fill */}
                    <path
                      d={hexPath}
                      stroke="none"
                      class="fill-white transition-all duration-500 group-[.active]:fill-blue"
                    />
                    {/* Border — visible only when active */}
                    <path
                      d={hexPath}
                      class="transition-all duration-500 group-[.active]:stroke-blue"
                      stroke-width="0.8"
                      stroke="none"
                    />
                  </svg>

                  {/* Number */}
                  <span class="relative z-10 font-display text-base font-bold text-navy transition-colors duration-500 group-[.active]:text-white md:text-xl">
                    {step.id}
                  </span>

                  {/* Decorative Pulse (only for active) */}
                  <div class="absolute inset-0 z-0 scale-125 rounded-full bg-blue opacity-0 blur-sm transition-all group-[.active]:animate-pulse group-[.active]:opacity-20" />
                </div>

                {/* Content Area */}
                <div class="pt-2 md:pt-4">
                  <div class="mb-2 flex flex-wrap items-center gap-4">
                    <h3 class="font-display text-xl font-bold uppercase tracking-wide text-navy md:text-2xl">
                      {step.title}
                    </h3>
                    <span class="text-navy/30 font-mono text-[10px] tracking-widest md:text-xs">
                      {step.coordinates}
                    </span>
                  </div>

                  <p class="backface-hidden text-navy/60 transform-gpu font-sans text-[15px] font-normal leading-relaxed">
                    {step.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  {/* ── Background Decorative Elements ── */}
  <div
    class="pointer-events-none absolute left-0 top-0 h-full w-full opacity-[0.03]"
  >
    <div
      class="absolute right-0 top-1/4 h-96 w-96 rounded-full bg-blue blur-[120px]"
    >
    </div>
  </div>
</section>

<script>
  const initProcessInteraction = () => {
    const section = document.querySelector("#process");
    const steps = document.querySelectorAll(".process-step");
    const progressBar = document.querySelector(
      "#process-progress-bar",
    ) as HTMLElement;

    if (!section || !steps.length || !progressBar) return;

    const updateProgress = () => {
      const rect = section.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      // Calculate how much of the section is visible
      // 0 at the bottom of viewport, 1 at the top
      const scrollProgress = Math.max(
        0,
        Math.min(
          1,
          (windowHeight - rect.top) / (rect.height + windowHeight * 0.2),
        ),
      );

      progressBar.style.transform = `scaleY(${scrollProgress})`;

      // Activate steps based on their position relative to viewport center
      steps.forEach((step, index) => {
        const stepRect = step.getBoundingClientRect();
        const stepCenter = stepRect.top + stepRect.height / 2;

        if (stepCenter < windowHeight * 0.7) {
          step.classList.add("active", "translate-y-0", "opacity-100");
          step.classList.remove("translate-y-8");
        }
      });
    };

    // Initial state
    steps.forEach((step) => {
      step.classList.add("translate-y-8");
    });

    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress(); // Run once to check visibility
  };

  // Support for both Astro Page Load and standard DOM Load
  document.addEventListener("DOMContentLoaded", initProcessInteraction);
  document.addEventListener("astro:page-load", initProcessInteraction);
</script>

<style>
  /* Custom easing for the progress bar if needed, 
     though tailwind duration-300 should be enough for basic smoothness */
</style>
