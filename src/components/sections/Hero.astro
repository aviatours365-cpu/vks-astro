---
import Button from "@/components/ui/Button.astro";
import { SECTIONS } from "@/lib/constants";
import { url } from "@/utils/url";
import { Picture } from "astro:assets";
import heroBg from "@/assets/bg-vks.png";

interface Props {
  titleHTML?: string;
  subtitle?: string;
  primaryButtonText?: string;
  primaryButtonHref?: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
}

const {
  titleHTML = SECTIONS.hero.titleHTML,
  subtitle = SECTIONS.hero.subtitle,
  primaryButtonText = SECTIONS.hero.primaryButtonText,
  primaryButtonHref = "#contact",
  secondaryButtonText = SECTIONS.hero.secondaryButtonText,
  secondaryButtonHref = "#services",
} = Astro.props;
---

<section
  id="hero"
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden md:min-h-svh"
>
  <div class="absolute inset-0 z-0 select-none">
    <Picture
      id="hero-bg"
      src={heroBg}
      alt="Hero Background"
      formats={["avif", "webp"]}
      widths={[640, 1024, 1920, 2560, 3840]}
      quality={100}
      class="absolute inset-0 h-full w-full object-cover object-[75%_center]"
      loading="eager"
      fetchpriority="high"
    />

    {/* Light Gradient Overlay for Text Readability (Left Side Only) */}
    <div
      class="pointer-events-none absolute inset-y-0 left-0 w-full bg-gradient-to-r from-white/95 via-white/80 to-transparent md:w-[70%]"
    >
    </div>
  </div>
  <div
    class="container relative z-10 mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 md:grid-cols-2 md:px-6"
  >
    {/* Text Content (Left) */}
    <div class="space-y-12 pt-12 md:pt-0">
      <div>
        <h1
          class="text-balance font-display text-[clamp(1.75rem,8vw,2.25rem)] font-bold uppercase leading-[1.1] tracking-tight text-navy sm:text-5xl md:text-6xl md:leading-[0.9] lg:text-5xl"
          set:html={titleHTML}
        />
        <p
          class="text-navy/70 mt-6 max-w-2xl font-sans text-base leading-relaxed md:text-lg lg:text-xl"
        >
          {subtitle}
        </p>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row">
        <Button
          variant="primary"
          size="lg"
          href={primaryButtonHref.startsWith("#")
            ? primaryButtonHref
            : url(primaryButtonHref)}
        >
          {primaryButtonText}
        </Button>
        <Button
          variant="outline"
          size="lg"
          href={secondaryButtonHref.startsWith("#")
            ? secondaryButtonHref
            : url(secondaryButtonHref)}
          className="hover:bg-navy/5 border-navy bg-transparent text-navy"
        >
          {secondaryButtonText}
        </Button>
      </div>
    </div>

    {/* Visual Placeholder (Right) - Empty for now, background does the work */}
    <div class="hidden h-full min-h-[400px] md:block">
      {/* Can place a 3D model or specific graphic here later */}
    </div>
  </div>
</section>

<script>
  let isMouseAttached = false;
  let rafId: number | null = null;
  let currentX = 0;
  let currentY = 0;
  let targetX = 0;
  let targetY = 0;

  // Linear interpolation for smoothness
  const lerp = (start: number, end: number, factor: number) =>
    start + (end - start) * factor;

  const handleMouseMove = (e: MouseEvent) => {
    if (window.innerWidth < 768) return;

    const { clientX, clientY } = e;
    const { innerWidth, innerHeight } = window;

    // Sensitivity (0.01)
    const sensitivity = 0.01;
    targetX = (clientX - innerWidth / 2) * sensitivity;
    targetY = (clientY - innerHeight / 2) * sensitivity;
  };

  document.addEventListener("astro:page-load", () => {
    const heroBg = document.getElementById("hero-bg");

    if (heroBg) {
      if (rafId) cancelAnimationFrame(rafId);
      currentX = 0;
      currentY = 0;
      targetX = 0;
      targetY = 0;

      const animate = () => {
        if (window.innerWidth >= 768) {
          // Smoothly interpolate towards target
          const diffX = targetX - currentX;
          const diffY = targetY - currentY;

          // Stop updating if very close to target to save resources
          if (Math.abs(diffX) > 0.1 || Math.abs(diffY) > 0.1) {
            currentX = lerp(currentX, targetX, 0.05);
            currentY = lerp(currentY, targetY, 0.05);
            // Reduced scale to minimize cropping while keeping motion smooth
            heroBg.style.transform = `scale(1.03) translate(${-currentX}px, ${-currentY}px)`;
          }
        } else {
          // Reset on mobile
          heroBg.style.transform = "scale(1.03) translate(0, 0)";
        }
        rafId = requestAnimationFrame(animate);
      };

      // Start animation loop
      animate();

      // Track mouse on WINDOW to avoid twitching when crossing element boundaries (like the header)
      if (!isMouseAttached) {
        window.addEventListener("mousemove", handleMouseMove);
        isMouseAttached = true;
      }
    } else {
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
    }
  });
</script>
