---
import Button from "@/components/ui/Button.astro";
import { SECTIONS } from "@/lib/constants";
import { url } from "@/utils/url";
import { Picture } from "astro:assets";
import heroBg from "@/assets/hero-bg.webp";

interface Props {
  titleHTML?: string;
  subtitle?: string;
  primaryButtonText?: string;
  primaryButtonHref?: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
}

const {
  titleHTML = SECTIONS.hero.titleHTML,
  subtitle = SECTIONS.hero.subtitle,
  primaryButtonText = SECTIONS.hero.primaryButtonText,
  primaryButtonHref = "/kontakty",
  secondaryButtonText = SECTIONS.hero.secondaryButtonText,
  secondaryButtonHref = "#services",
} = Astro.props;
---

<section
  class="relative flex min-h-screen items-center overflow-hidden bg-white pt-20"
>
  <div class="absolute inset-0 z-0 select-none">
    <Picture
      id="hero-bg"
      src={heroBg}
      alt="Hero Background"
      formats={["avif", "webp"]}
      widths={[640, 1024, 1920]}
      class="absolute inset-0 h-full w-full scale-110 object-cover"
      loading="eager"
      fetchpriority="high"
    />

    <!-- Light Gradient Overlay for Text Readability (Left Side Only) -->
    <div
      class="pointer-events-none absolute inset-y-0 left-0 w-full bg-gradient-to-r from-white/95 via-white/80 to-transparent md:w-[70%]"
    >
    </div>

    <!-- Flickering Effect Overlay -->
    <!-- Positioned to match the blue hexagon in the generated image (approximate, needs manual tuning based on image) -->
    <div
      class="bg-blue/40 absolute right-[18%] top-[48%] hidden h-[220px] w-[220px] -translate-y-1/2 animate-flicker rounded-full blur-[50px] md:block"
    >
    </div>
  </div>

  <div
    class="container relative z-10 grid grid-cols-1 items-center gap-12 md:grid-cols-2"
  >
    {/* Text Content (Left) */}
    <div class="space-y-12 pt-12 md:pt-0">
      <div>
        <h1
          class="font-display text-4xl font-bold uppercase leading-none tracking-tight text-navy sm:text-5xl md:text-6xl md:leading-[0.9] lg:text-7xl"
          set:html={titleHTML}
        />
        <p
          class="text-navy/80 mt-6 max-w-[50ch] font-sans text-[16px] font-light leading-[1.5] md:text-2xl"
        >
          {subtitle}
        </p>
      </div>

      <div class="flex flex-col gap-4 sm:flex-row">
        <Button
          variant="primary"
          size="lg"
          href={url(primaryButtonHref)}
          className="rounded-full uppercase"
        >
          {primaryButtonText}
        </Button>
        <Button
          variant="outline"
          size="lg"
          href={secondaryButtonHref.startsWith("#")
            ? secondaryButtonHref
            : url(secondaryButtonHref)}
          className="hover:bg-navy/5 rounded-full border-navy bg-transparent uppercase text-navy"
        >
          {secondaryButtonText}
        </Button>
      </div>
    </div>

    {/* Visual Placeholder (Right) - Empty for now, background does the work */}
    <div class="hidden h-full min-h-[400px] md:block">
      {/* Can place a 3D model or specific graphic here later */}
    </div>
  </div>
</section>

<script>
  let isMouseAttached = false;
  let rafId: number | null = null;
  let currentX = 0;
  let currentY = 0;
  let targetX = 0;
  let targetY = 0;

  // Linear interpolation for smoothness
  const lerp = (start: number, end: number, factor: number) =>
    start + (end - start) * factor;

  const handleMouseMove = (e: MouseEvent) => {
    if (window.innerWidth < 768) return;

    const { clientX, clientY } = e;
    const { innerWidth, innerHeight } = window;

    // Sensitivity (0.01)
    const sensitivity = 0.01;
    targetX = (clientX - innerWidth / 2) * sensitivity;
    targetY = (clientY - innerHeight / 2) * sensitivity;
  };

  document.addEventListener("astro:page-load", () => {
    const heroBg = document.getElementById("hero-bg");

    if (heroBg) {
      if (rafId) cancelAnimationFrame(rafId);
      currentX = 0;
      currentY = 0;
      targetX = 0;
      targetY = 0;

      const animate = () => {
        if (window.innerWidth >= 768) {
          // Smoothly interpolate towards target
          const diffX = targetX - currentX;
          const diffY = targetY - currentY;

          // Stop updating if very close to target to save resources
          if (Math.abs(diffX) > 0.1 || Math.abs(diffY) > 0.1) {
            currentX = lerp(currentX, targetX, 0.05);
            currentY = lerp(currentY, targetY, 0.05);
            heroBg.style.transform = `scale(1.1) translate(${-currentX}px, ${-currentY}px)`;
          }
        } else {
          // Reset on mobile
          heroBg.style.transform = "scale(1.1) translate(0, 0)";
        }
        rafId = requestAnimationFrame(animate);
      };

      // Start animation loop
      animate();

      // Track mouse on WINDOW to avoid twitching when crossing element boundaries (like the header)
      if (!isMouseAttached) {
        window.addEventListener("mousemove", handleMouseMove);
        isMouseAttached = true;
      }
    } else {
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
    }
  });
</script>
