---
import { SECTIONS } from "@/lib/constants";
import { getCollection } from "astro:content";
import Icon from "@/components/ui/Icon.astro";
import SolutionCard from "@/components/ui/SolutionCard.astro";
import SolutionAccordion from "@/components/ui/SolutionAccordion.astro";

interface Props {
  title?: string;
  subtitle?: string;
  labels?: {
    directions: string;
    solution: string;
    features: string;
  };
}

const {
  title = SECTIONS.solutions.title,
  subtitle = SECTIONS.solutions.subtitle,
  labels = SECTIONS.solutions.labels,
} = Astro.props;

const solutions = (await getCollection("solutions")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="solutions" class="relative bg-white py-12 md:py-16 lg:py-20">
  <div class="container mx-auto max-w-7xl px-4 md:px-6">
    <div class="mb-10 md:mb-12 lg:mb-14">
      <h2
        class="font-display text-3xl font-bold uppercase leading-[1.1] tracking-tight text-navy md:text-4xl lg:text-[2.75rem]"
      >
        {title}
      </h2>
      {
        subtitle && (
          <p class="text-navy/70 mt-6 max-w-2xl font-sans text-base leading-relaxed md:text-lg lg:text-xl">
            {subtitle}
          </p>
        )
      }
    </div>

    {/* ── DESKTOP: Split-Screen ── */}
    <div class="relative hidden gap-16 lg:flex xl:gap-20">
      {/* Left Column — Sticky Nav */}
      <div class="relative w-[280px] shrink-0 self-stretch">
        <div class="sticky top-28 h-max">
          <div
            class="overflow-hidden rounded-xl border border-[#e1e1e1] bg-white"
          >
            <div class="border-b border-[#e1e1e1] px-6 py-4">
              <h4
                class="text-navy/30 font-display text-[10px] font-bold uppercase tracking-[0.2em]"
              >
                {labels.directions}
              </h4>
            </div>
            <nav class="flex flex-col p-2" id="editorial-nav">
              {
                solutions.map((item, index: number) => (
                  <a
                    href={`#ea-${item.id}`}
                    class={`editorial-nav-item group/nav flex items-center gap-3.5 rounded-lg px-4 py-3.5 transition-all duration-300 ${index === 0 ? "bg-navy text-white shadow-brand" : "text-navy/60 hover:bg-surface hover:text-navy"}`}
                    data-target={`ea-${item.id}`}
                  >
                    <Icon
                      name={item.data.icon as any}
                      size={20}
                      class={`shrink-0 transition-colors duration-300 ${index === 0 ? "text-white" : "text-navy/30 group-hover/nav:text-blue"}`}
                    />
                    <span class="font-display text-[11px] font-bold uppercase tracking-[0.05em]">
                      {item.data.title}
                    </span>
                  </a>
                ))
              }
            </nav>
          </div>
        </div>
      </div>

      {/* Right Column — Content */}
      <div class="min-w-0 flex-1" id="editorial-content">
        {
          solutions.map((item, index: number) => (
            <SolutionCard
              product={{ id: item.id, ...item.data }}
              index={index}
              labels={labels}
            />
          ))
        }
      </div>
    </div>

    {/* ── MOBILE: Accordion ── */}
    <div class="lg:hidden">
      {
        solutions.map((item, index: number) => (
          <SolutionAccordion
            product={{ id: item.id, ...item.data }}
            index={index}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { initSolutionsEditorial } from "@/scripts/solutions-init";
  initSolutionsEditorial();
  document.addEventListener("astro:page-load", initSolutionsEditorial);
</script>
