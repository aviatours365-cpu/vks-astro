---
import { SECTIONS } from "@/lib/constants";
import Icon from "@/components/ui/Icon.astro";

interface Props {
  title?: string;
  subtitle?: string;
  principles?: readonly {
    readonly id: string;
    readonly label: string;
    readonly icon: string;
    readonly title: string;
    readonly description: string;
  }[];
}

const {
  title = SECTIONS.about.title,
  subtitle = SECTIONS.about.subtitle,
  principles = SECTIONS.about.principles,
} = Astro.props;

/* Vertical offset classes for the staggered "staircase" effect (desktop only) */
const offsets = ["md:mt-0", "md:mt-8", "md:mt-16"];
---

<section id="about" class="relative bg-surface py-12 md:py-16 lg:py-20">
  <div class="container mx-auto max-w-7xl px-4 md:px-6">
    {/* ── Standard Stacked Header (VKS SECTION SPEC) ── */}
    <div class="mb-10 md:mb-12 lg:mb-12">
      <h2
        class="font-display text-3xl font-bold uppercase leading-[1.1] tracking-tight text-navy md:text-4xl lg:text-[2.75rem]"
      >
        {title}
      </h2>
      {
        subtitle && (
          <p class="text-navy/70 mt-6 max-w-2xl font-sans text-base leading-relaxed md:text-lg lg:text-xl">
            {subtitle}
          </p>
        )
      }
    </div>

    {/* ── Stagger Grid ── */}
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3 md:gap-8 lg:gap-8">
      {
        principles.map((principle, index) => (
          <div
            class={`about-card group translate-y-5 opacity-0 transition-all duration-700 ease-out ${offsets[index]}`}
            style={`transition-delay: ${index * 150}ms;`}
          >
            <div class="flex h-auto transform-gpu flex-col rounded-2xl bg-white p-6 shadow-[0_2px_12px_rgba(0,31,63,0.06)] transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] will-change-transform group-hover:-translate-y-1 group-hover:shadow-[0_12px_40px_rgba(0,123,255,0.1)] md:h-[320px] md:p-8 lg:p-10">
              {/* Brand-Standard Header: Icon + Stacked Labels */}
              <div class="backface-hidden mb-8 flex transform-gpu items-start gap-5">
                <div class="icon-shine shrink-0">
                  <Icon
                    name={principle.icon as any}
                    size={56}
                    class="text-blue transition-colors duration-500"
                  />
                </div>
                <div class="flex flex-col pt-1">
                  <p class="text-navy/40 mb-1 font-mono text-[10px] uppercase tracking-[0.2em]">
                    {principle.label}
                  </p>
                  <h3 class="font-display text-xl font-bold uppercase leading-tight tracking-wider text-navy transition-colors duration-300 group-hover:text-blue">
                    {principle.title}
                  </h3>
                </div>
              </div>

              <p class="backface-hidden text-navy/60 transform-gpu font-sans text-[15px] font-normal leading-relaxed">
                {principle.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const initAboutReveal = () => {
    const cards = document.querySelectorAll(".about-card");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove("opacity-0", "translate-y-5");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
    );
    cards.forEach((card) => observer.observe(card));
  };

  initAboutReveal();
  document.addEventListener("astro:page-load", initAboutReveal);
</script>
