---
import { MAP_HOTSPOTS } from "@/lib/map-data";
import { Image } from "astro:assets";
import belarusMapBg from "@/assets/belarus-map-bg.png";
import MapMarker from "@/components/ui/MapMarker.astro";
import MapMobileSlider from "@/components/ui/MapMobileSlider.astro";
import { SECTIONS } from "@/lib/constants";

export interface Props {
  titleHTML?: string;
  descriptionHTML?: string;
  counters?: {
    target: number;
    prefix?: string;
    suffix?: string;
    labelHTML: string;
  }[];
}

const {
  titleHTML = SECTIONS.map.titleHTML,
  descriptionHTML = SECTIONS.map.descriptionHTML,
  counters = SECTIONS.map.defaultCounters as any,
} = Astro.props;

// For mobile slider rendering
const mobileStats = [...MAP_HOTSPOTS, SECTIONS.map.allRegionsHotspot];
---

<section
  id="map"
  class="relative overflow-hidden bg-white py-12 md:py-16 lg:py-0"
  aria-label="Карта внедрений"
>
  <div class="container mx-auto max-w-7xl px-4 md:px-6">
    <div class="grid w-full grid-cols-1 gap-10 lg:grid-cols-12">
      {/* ЛЕВАЯ ЧАСТЬ: Текст и Счетчики */}
      <div
        class="flex flex-col justify-center space-y-10 lg:col-span-5 xl:col-span-4"
      >
        <div class="mb-2">
          <h2
            class="font-display text-3xl font-bold uppercase leading-[1.1] tracking-tight text-navy md:text-4xl lg:text-[2.75rem]"
            set:html={titleHTML}
          />
          <p
            class="text-navy/70 mt-6 max-w-md font-sans text-base leading-relaxed md:text-lg lg:text-xl"
            set:html={descriptionHTML}
          />
        </div>

        <div class="grid grid-cols-2 gap-x-8 gap-y-10" id="map-counters">
          {
            counters.map((counter: any) => (
              <div>
                <div class="font-display text-4xl font-black tracking-tighter text-navy lg:text-5xl">
                  {counter.prefix && (
                    <span class="mr-1 text-blue">{counter.prefix}</span>
                  )}
                  <span class="stat-counter" data-target={counter.target}>
                    0
                  </span>
                  {counter.suffix && (
                    <span class="text-blue">{counter.suffix}</span>
                  )}
                </div>
                <p
                  class="text-navy/60 mt-3 text-[11px] font-bold uppercase tracking-[0.05em]"
                  set:html={counter.labelHTML}
                />
              </div>
            ))
          }
        </div>
      </div>

      {/* ПРАВАЯ ЧАСТЬ: Карта (Десктоп) */}
      <div
        class="relative hidden min-h-[600px] items-center justify-center lg:col-span-7 lg:flex xl:col-span-8"
      >
        {/* Контейнер Карты (строго по размеру изображения) */}
        <div class="relative w-full max-w-[900px]">
          {/* Картинка подложки - mix-blend-multiply убирает белый фон! */}
          <Image
            src={belarusMapBg}
            alt="Карта Беларуси"
            class="pointer-events-none block h-auto w-full opacity-90 mix-blend-multiply"
            loading="lazy"
          />

          {/* Маркеры поверх контейнера */}
          <div class="absolute inset-0 z-10 h-full w-full">
            {MAP_HOTSPOTS.map((hotspot) => <MapMarker {...hotspot} />)}
          </div>
        </div>
      </div>
    </div>

    {/* МОБИЛЬНАЯ ВЕРСИЯ (Без изображения карты) */}
    <MapMobileSlider stats={mobileStats} />
  </div>
</section>

<script>
  function initCounters() {
    const counters = document.querySelectorAll(".stat-counter");
    if (!counters.length) return;

    let hasAnimated = false;

    const animateCounters = () => {
      counters.forEach((counter) => {
        const target = parseInt(counter.getAttribute("data-target") || "0", 10);
        const duration = 2000;
        const start = performance.now();

        const update = (currentTime: number) => {
          const elapsed = currentTime - start;
          const progress = Math.min(elapsed / duration, 1);

          // easeOutExpo
          const easeProgress =
            progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);

          if (counter.textContent) {
            counter.textContent = Math.floor(easeProgress * target).toString();
          }

          if (progress < 1) {
            requestAnimationFrame(update);
          } else {
            if (counter.textContent) counter.textContent = target.toString();
          }
        };

        requestAnimationFrame(update);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasAnimated) {
            hasAnimated = true;
            animateCounters();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 },
    );

    const counterSection = document.getElementById("map-counters");
    if (counterSection) {
      observer.observe(counterSection);
    }
  }

  // Handle Astro view transitions if they are used
  document.addEventListener("astro:page-load", initCounters);
  // Also run on DOMContentLoaded for initial load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCounters);
  } else {
    initCounters();
  }
</script>
