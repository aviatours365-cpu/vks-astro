---
import { SECTIONS, CONTACTS } from "@/lib/constants";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";
import HexBadge from "@/components/ui/HexBadge.astro";
import { Picture } from "astro:assets";
import heroBg from "@/assets/hero-bg.webp";

interface Props {
  titleHTML?: string;
  subtitle?: string;
}

const {
  titleHTML = SECTIONS.leadGen.titleHTML,
  subtitle = SECTIONS.leadGen.subtitle,
} = Astro.props;

const { form, success } = SECTIONS.leadGen;
---

<section
  id="contact"
  class="relative overflow-hidden bg-white py-12 md:py-16 lg:py-20"
>
  {/* Background and Gradient — EXACT COPY from Hero.astro for visual 1:1 identity */}
  <div class="absolute inset-0 z-0 select-none">
    <Picture
      id="lead-gen-bg"
      src={heroBg}
      alt="Background"
      formats={["avif", "webp"]}
      widths={[640, 1024, 1920]}
      class="absolute inset-0 h-full w-full scale-110 object-cover"
      loading="lazy"
    />

    <!-- Light Gradient Overlay for Text Readability (Left Side Only) -->
    <div
      class="pointer-events-none absolute inset-y-0 left-0 w-full bg-gradient-to-r from-white/95 via-white/80 to-transparent md:w-[70%]"
    >
    </div>

    <!-- Flickering Effect Overlay -->
    <div
      class="bg-blue/40 absolute right-[18%] top-[48%] hidden h-[220px] w-[220px] -translate-y-1/2 animate-flicker rounded-full blur-[50px] md:block"
    >
    </div>
  </div>
  <div class="container relative z-10 mx-auto max-w-7xl px-4 md:px-6">
    <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 lg:gap-24">
      {/* ── Left Column: Contact info ── */}
      <div class="flex flex-col">
        <h2
          class="font-display text-3xl font-bold uppercase leading-[1.1] tracking-tight text-navy md:text-4xl lg:text-[2.75rem]"
          set:html={titleHTML}
        />

        <p
          class="text-navy/70 mt-6 max-w-lg font-sans text-base leading-relaxed md:text-lg lg:text-xl"
        >
          {subtitle}
        </p>

        <div class="mt-12 space-y-10">
          <div class="flex items-start gap-5">
            <Icon
              name="mail-hex"
              size={56}
              class="shrink-0 text-blue transition-colors duration-500"
            />
            <div>
              <p
                class="text-navy/40 mb-1 font-mono text-[10px] uppercase tracking-[0.2em]"
              >
                Email
              </p>
              <a
                href={`mailto:${CONTACTS.email}`}
                class="font-display text-xl font-bold text-navy transition-colors duration-300 hover:text-blue"
              >
                {CONTACTS.email}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-5">
            <Icon
              name="phone-hex"
              size={56}
              class="shrink-0 text-blue transition-colors duration-500"
            />
            <div>
              <p
                class="text-navy/40 mb-1 font-mono text-[10px] uppercase tracking-[0.2em]"
              >
                Телефоны
              </p>
              <div
                class="grid grid-cols-1 gap-x-8 gap-y-4 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2"
              >
                {
                  CONTACTS.phones.map((phone) => (
                    <div class="flex flex-col">
                      <span class="text-navy/30 font-mono text-[9px] uppercase tracking-wider">
                        {phone.label}
                      </span>
                      <a
                        href={`tel:${phone.value.replace(/\D/g, "")}`}
                        class="whitespace-nowrap font-display text-lg font-bold text-navy transition-colors duration-300 hover:text-blue"
                      >
                        {phone.value}
                      </a>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* ── Right Column: Lead Form Container ── */}
      <div class="group/form relative min-h-[500px]">
        <div
          class="h-full rounded-2xl bg-white p-8 shadow-[0_2px_12px_rgba(0,31,63,0.06)] transition-all duration-500 ease-out group-hover/form:-translate-y-1 group-hover/form:shadow-[0_12px_40px_rgba(0,123,255,0.1)] md:p-12 lg:p-14"
        >
          {/* Form Content */}
          <div
            id="form-container"
            class="relative h-full transition-all duration-700"
          >
            <form
              id="lead-form"
              class="flex flex-col gap-5 transition-all duration-500"
              novalidate
            >
              <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
                <div class="group relative">
                  <input
                    type="text"
                    name="name"
                    placeholder={form.name}
                    required
                    class="border-navy/10 placeholder:text-navy/30 peer w-full border-b bg-transparent py-3 font-sans text-navy outline-none transition-all duration-300 placeholder:transition-opacity focus:placeholder:opacity-0"
                  />
                  <div
                    class="absolute bottom-0 left-1/2 h-0.5 w-0 -translate-x-1/2 bg-blue transition-all duration-500 peer-focus:w-full peer-[.is-invalid]:w-full peer-[.is-invalid]:bg-error"
                  >
                  </div>
                  <p
                    class="error-message pointer-events-none absolute right-0 top-3 translate-x-2 font-mono text-[9px] font-bold uppercase tracking-[0.2em] text-error opacity-0 transition-all duration-300"
                  >
                    {form.errors.required}
                  </p>
                </div>
                <div class="group relative">
                  <input
                    type="text"
                    name="company"
                    placeholder={form.company}
                    class="border-navy/10 placeholder:text-navy/30 peer w-full border-b bg-transparent py-3 font-sans text-navy outline-none transition-all duration-300 placeholder:transition-opacity focus:placeholder:opacity-0"
                  />
                  <div
                    class="absolute bottom-0 left-1/2 h-0.5 w-0 -translate-x-1/2 bg-blue transition-all duration-500 peer-focus:w-full"
                  >
                  </div>
                </div>
              </div>

              <div class="group relative">
                <input
                  type="text"
                  name="contact"
                  placeholder={form.contact}
                  required
                  class="border-navy/10 placeholder:text-navy/30 peer w-full border-b bg-transparent py-3 font-sans text-navy outline-none transition-all duration-300 placeholder:transition-opacity focus:placeholder:opacity-0"
                />
                <div
                  class="absolute bottom-0 left-1/2 h-0.5 w-0 -translate-x-1/2 bg-blue transition-all duration-500 peer-focus:w-full peer-[.is-invalid]:w-full peer-[.is-invalid]:bg-error"
                >
                </div>
                <p
                  class="error-message pointer-events-none absolute right-0 top-3 translate-x-2 font-mono text-[9px] font-bold uppercase tracking-[0.2em] text-error opacity-0 transition-all duration-300"
                >
                  {form.errors.required}
                </p>
              </div>

              <div class="group relative">
                <textarea
                  name="message"
                  placeholder={form.message}
                  rows="3"
                  class="border-navy/10 placeholder:text-navy/30 peer w-full resize-none border-b bg-transparent py-3 font-sans text-navy outline-none transition-all duration-300 placeholder:transition-opacity focus:border-transparent focus:placeholder:opacity-0"
                ></textarea>
                <div
                  class="absolute bottom-0 left-1/2 h-0.5 w-0 -translate-x-1/2 bg-blue transition-all duration-500 peer-focus:w-full"
                >
                </div>
              </div>

              <div class="mt-4">
                <Button
                  type="submit"
                  variant="primary"
                  size="lg"
                  className="h-16 w-full text-lg uppercase tracking-widest"
                >
                  {form.submit}
                </Button>

                <p
                  class="text-navy/40 mb-1 py-3 font-mono text-[10px] uppercase tracking-[0.2em]"
                >
                  {form.agreement}
                </p>
              </div>
            </form>

            {/* Success State Overlay */}
            <div
              id="form-success"
              class="pointer-events-none absolute inset-0 z-20 flex flex-col items-center justify-center opacity-0 transition-all duration-700"
            >
              {/* Brand-Standard Iconography: Blue Hexagon with Blue Check */}
              <div class="relative mb-10 flex items-center justify-center">
                <Icon
                  name="check"
                  size={100}
                  class="text-blue transition-all duration-700"
                />
              </div>

              <h3
                class="mb-4 text-center font-display text-3xl font-bold uppercase tracking-tight text-navy"
              >
                {success.title}
              </h3>
              <p
                class="mx-auto text-center text-navy/60 max-w-lg font-sans text-base leading-relaxed md:text-lg"
              >
                {success.message}
              </p>

              <button
                id="form-reset-minimal"
                class="text-navy/30 mt-14 font-mono text-[10px] font-bold uppercase tracking-[0.3em] transition-all duration-300 hover:tracking-[0.4em] hover:text-blue"
              >
                Вернуться назад
              </button>
            </div>
          </div>
        </div>

        {/* Decorative elements behind container */}
        <div
          class="bg-blue/5 absolute -right-8 -top-8 -z-10 h-32 w-32 rounded-full blur-3xl"
        >
        </div>
        <div
          class="bg-blue/10 absolute -bottom-12 -left-12 -z-10 h-48 w-48 rounded-full blur-[80px]"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const initLeadForm = () => {
    const form = document.querySelector("#lead-form") as HTMLFormElement;
    const successOverlay = document.querySelector("#form-success");
    const resetBtn = document.querySelector("#form-reset-minimal");

    if (!form || !successOverlay || !resetBtn) return;

    // Custom Validation Handling
    const inputs = form.querySelectorAll("input[required]");

    const showError = (input: HTMLInputElement) => {
      input.classList.add("is-invalid");
      const errorMessage = input.parentElement?.querySelector(".error-message");
      if (errorMessage) {
        errorMessage.classList.remove("opacity-0", "translate-x-2");
        errorMessage.classList.add("opacity-100", "translate-x-0");
      }
    };

    const hideError = (input: HTMLInputElement) => {
      input.classList.remove("is-invalid");
      const errorMessage = input.parentElement?.querySelector(".error-message");
      if (errorMessage) {
        errorMessage.classList.add("opacity-0", "translate-x-2");
        errorMessage.classList.remove("opacity-100", "translate-x-0");
      }
    };

    inputs.forEach((input) => {
      const el = input as HTMLInputElement;
      el.addEventListener("input", () => {
        if (el.validity.valid) hideError(el);
      });
      el.addEventListener("blur", () => {
        if (!el.validity.valid && el.value.trim() !== "") showError(el);
      });
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Check all required inputs
      let isValid = true;
      inputs.forEach((input) => {
        const el = input as HTMLInputElement;
        if (!el.validity.valid) {
          showError(el);
          isValid = false;
        }
      });

      if (!isValid) return;

      const submitBtn = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;

      if (submitBtn) {
        submitBtn.disabled = true;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = "ОТПРАВКА...";

        setTimeout(() => {
          // Immersive transition
          form.classList.add(
            "opacity-0",
            "pointer-events-none",
            "scale-95",
            "blur-sm",
          );

          setTimeout(() => {
            successOverlay.classList.remove("opacity-0", "pointer-events-none");
            successOverlay.classList.add("opacity-100");
          }, 300);

          submitBtn.disabled = false;
          submitBtn.innerText = originalText;
        }, 1500);
      }
    });

    resetBtn.addEventListener("click", () => {
      successOverlay.classList.add("opacity-0", "pointer-events-none");
      successOverlay.classList.remove("opacity-100");

      setTimeout(() => {
        form.classList.remove(
          "opacity-0",
          "pointer-events-none",
          "scale-95",
          "blur-sm",
        );
        form.reset();
        // Hide all errors on reset
        inputs.forEach((input) => hideError(input as HTMLInputElement));
      }, 300);
    });
  };

  document.addEventListener("DOMContentLoaded", initLeadForm);
  document.addEventListener("astro:page-load", initLeadForm);
</script>
