---
import { SECTIONS, CONTACTS } from "@/lib/constants";
import Icon from "@/components/ui/Icon.astro";
import FeedbackForm from "@/components/ui/FeedbackForm.astro";
import { Picture } from "astro:assets";
import heroBg from "@/assets/bg-vks.png";

interface Props {
  titleHTML?: string;
  subtitle?: string;
}

const {
  titleHTML = SECTIONS.leadGen.titleHTML,
  subtitle = SECTIONS.leadGen.subtitle,
} = Astro.props;

const { form, success } = SECTIONS.leadGen;
---

<section
  id="contact"
  class="relative flex min-h-screen flex-col justify-center overflow-hidden bg-white py-12 md:py-24 lg:py-32"
>
  <div class="absolute inset-0 z-0 select-none">
    <Picture
      id="lead-gen-bg"
      src={heroBg}
      alt="Background"
      formats={["avif", "webp"]}
      widths={[640, 1024, 1920, 2560, 3840]}
      quality={100}
      class="absolute inset-0 h-full w-full object-cover object-[75%_center]"
      loading="lazy"
    />
    <div
      class="pointer-events-none absolute inset-y-0 left-0 w-full bg-gradient-to-r from-white/95 via-white/80 to-transparent md:w-[70%]"
    >
    </div>
  </div>

  <div class="container relative z-10 mx-auto max-w-7xl px-4 md:px-6">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-x-24 lg:gap-y-0">
      {/* ── 1. Header (Title + Subtitle) ── */}
      <div class="order-1">
        <h2
          class="font-display text-4xl font-bold uppercase leading-none tracking-tight text-navy sm:text-5xl md:text-6xl lg:text-[2.75rem] lg:leading-[2.75rem]"
          set:html={titleHTML}
        />
        <p
          class="text-navy/70 mt-6 max-w-lg font-sans text-base leading-relaxed md:text-lg lg:text-xl"
        >
          {subtitle}
        </p>
      </div>

      {/* ── 2. Feedback Form ── */}
      <div class="order-2 lg:row-span-2">
        <FeedbackForm form={form} success={success} />
      </div>

      {/* ── 3. Contact Info (Email, Phones, Address) ── */}
      <div class="order-3 lg:mt-8 lg:self-start">
        <div class="space-y-4 lg:space-y-6">
          <div class="group flex items-start gap-4">
            <div class="icon-shine shrink-0">
              <Icon
                name="mail-hex"
                size={32}
                class="text-blue transition-colors duration-500 md:h-12 md:w-12"
              />
            </div>
            <div
              class="flex min-h-[32px] flex-col justify-center md:min-h-[56px]"
            >
              <a
                href={`mailto:${CONTACTS.email}`}
                class="font-sans text-base font-normal text-navy transition-colors duration-300 hover:text-blue md:font-display md:text-xl md:font-bold"
              >
                {CONTACTS.email}
              </a>
            </div>
          </div>

          <div class="group flex items-start gap-4">
            <div class="icon-shine shrink-0">
              <Icon
                name="phone-hex"
                size={32}
                class="text-blue transition-colors duration-500 md:h-12 md:w-12"
              />
            </div>
            <div
              class="flex min-h-[32px] flex-col justify-center md:min-h-[56px]"
            >
              <div
                class="grid grid-cols-1 gap-x-8 gap-y-1 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2"
              >
                {
                  CONTACTS.phones.map((phone) => (
                    <a
                      href={`tel:${phone.value.replace(/\D/g, "")}`}
                      class="whitespace-nowrap font-sans text-base font-normal text-navy transition-colors duration-300 hover:text-blue md:font-display md:text-xl md:font-bold"
                    >
                      {phone.value}
                    </a>
                  ))
                }
              </div>
            </div>
          </div>

          <div class="group flex items-start gap-4">
            <div class="icon-shine shrink-0">
              <Icon
                name="telegram-hex"
                size={32}
                class="text-blue transition-colors duration-500 md:h-12 md:w-12"
              />
            </div>
            <div
              class="flex min-h-[32px] flex-col justify-center md:min-h-[56px]"
            >
              <a
                href={CONTACTS.socials[0].href}
                target="_blank"
                rel="noopener noreferrer"
                class="font-sans text-base font-normal text-navy transition-colors duration-300 hover:text-blue md:font-display md:text-xl md:font-bold"
              >
                Telegram
              </a>
            </div>
          </div>
          <div class="group flex items-start gap-4">
            <div class="icon-shine shrink-0">
              <Icon
                name="map-pin-hex"
                size={32}
                class="text-blue transition-colors duration-500 md:h-12 md:w-12"
              />
            </div>
            <div
              class="flex min-h-[32px] flex-col justify-center md:min-h-[56px]"
            >
              <address
                class="text-navy/70 font-sans text-base not-italic leading-relaxed md:font-display md:text-lg md:font-bold md:text-navy"
              >
                {CONTACTS.address.full.join(", ")}
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
