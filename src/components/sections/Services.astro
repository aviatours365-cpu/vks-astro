---
import ServiceCard from "@/components/ui/ServiceCard.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="services" class="relative overflow-hidden py-16 md:py-32">
  <div class="container relative z-10 mx-auto px-4 md:px-6">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 max-w-3xl md:mb-16">
        <h2
          class="font-display text-[32px] font-bold uppercase tracking-tight text-navy md:text-5xl"
        >
          {title}
        </h2>
        {
          subtitle && (
            <p class="text-navy/70 mt-4 font-sans text-[16px] leading-relaxed md:text-[18px]">
              {subtitle}
            </p>
          )
        }
      </div>

      <div
        class="-mx-4 flex items-stretch w-full snap-x snap-mandatory gap-6 overflow-x-auto px-4 pb-8 md:mx-0 md:grid md:grid-cols-2 md:gap-8 md:overflow-visible md:px-0 md:pb-0 lg:grid-cols-3 [&::-webkit-scrollbar]:hidden"
      >
        {
          services.map((s) => (
            <ServiceCard
              slug={s.id}
              icon={s.data.icon}
              title={s.data.title}
              description={s.data.description}
              full={s.data.full}
              className="w-[280px] shrink-0 snap-center md:w-full"
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
