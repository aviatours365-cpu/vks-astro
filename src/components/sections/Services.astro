---
import ServiceCard from "@/components/ui/ServiceCard.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
}

const { title } = Astro.props;

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="services" class="relative overflow-hidden bg-white py-16 md:py-32">
  <div class="container relative z-10 mx-auto px-4 md:px-6">
    <div class="mx-auto max-w-7xl">
      <h2
        class="mb-10 font-display text-[32px] font-bold uppercase tracking-tight text-navy md:mb-16 md:text-5xl"
      >
        {title}
      </h2>

      <div
        class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 lg:grid-cols-3"
      >
        {
          services.map((s) => (
            <ServiceCard
              slug={s.id}
              icon={s.data.icon}
              title={s.data.title}
              description={s.data.description}
              full={s.data.full}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
