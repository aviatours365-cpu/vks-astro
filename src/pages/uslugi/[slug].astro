---
import { getCollection, render } from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";
import Icon from "@/components/ui/Icon.astro";

// 1. Generate static paths for every service in the `services` collection
export async function getStaticPaths() {
  const servicesEntries = await getCollection("services");
  return servicesEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

// 2. Fetch the props passed by getStaticPaths
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PageLayout title={`${entry.data.title} | VKS Group`}>
  <main class="flex-grow bg-white py-24 md:py-32">
    <div class="container mx-auto px-4 md:px-6">
      <div class="mx-auto max-w-4xl pt-8">
        <Icon name={entry.data.icon as any} size={64} class="mb-8 text-blue" />

        <h1
          class="mb-8 font-display text-[32px] font-bold uppercase tracking-tight text-navy md:text-5xl"
        >
          {entry.data.title}
        </h1>

        <p
          class="text-navy/70 mb-16 max-w-3xl text-lg font-light leading-relaxed md:text-xl"
        >
          {entry.data.description}
          {entry.data.full}
        </p>

        {
          /* Render the actual Markdown content body using Tailwind Typography */
        }
        <div
          class="prose-navy prose max-w-none prose-h2:font-display prose-h2:uppercase prose-a:text-blue hover:prose-a:text-navy"
        >
          <Content />
        </div>
      </div>
    </div>
  </main>
</PageLayout>
